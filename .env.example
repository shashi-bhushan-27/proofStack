# ===========================================
# proofStack Environment Configuration
# ===========================================

# Database
DATABASE_URL=postgresql+asyncpg://proofstack:proofstack@localhost:5432/proofstack
POSTGRES_USER=proofstack
POSTGRES_PASSWORD=proofstack
POSTGRES_DB=proofstack

# Auth / Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM (Groq - free tier)
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# S3 File Storage
S3_BUCKET_NAME=proofstack-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# For Cloudflare R2, set endpoint:
# S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# App Config
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# NextAuth (Frontend)
AUTH_SECRET=change-this-to-a-random-auth-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
